# MongoDB connection string (MongoDB Atlas recommended for production)
MONGO_URL=mongodb://127.0.0.1:27017/Mern-Pizza

# JWT secret — use a long random string in production
JWT_SECRET=your_jwt_secret_here

# Stripe secret key (server-side only)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key

# Optional: frontend URL for CORS (production)
CLIENT_URL=http://localhost:3000

# Optional: seed script defaults
ADMIN_EMAIL=admin@bundopizza.com
ADMIN_PASSWORD=Admin123!
